<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Roblox</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Roboto', sans-serif;
            background: #0f0f0f;
            color: #fff;
            overflow: hidden;
            height: 100vh;
        }
        
        .top-nav {
            background: #111;
            height: 60px;
            display: flex;
            align-items: center;
            padding: 0 20px;
            border-bottom: 1px solid #333;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }
        
        .logo {
            font-size: 32px;
            font-weight: bold;
            color: #00a2ff;
            margin-left: 10px;
            cursor: pointer;
        }
        
        .search-bar {
            flex: 1;
            max-width: 500px;
            margin: 0 20px;
            background: #222;
            border-radius: 30px;
            padding: 8px 16px;
            display: flex;
            align-items: center;
        }
        
        .search-bar input {
            background: transparent;
            border: none;
            color: #fff;
            width: 100%;
            outline: none;
        }
        
        .nav-links {
            display: flex;
            gap: 25px;
            margin: 0 20px;
        }
        
        .nav-links a {
            color: #ddd;
            text-decoration: none;
            font-weight: 500;
            cursor: pointer;
        }
        
        .nav-links a:hover, .nav-links a.active {
            color: #00a2ff;
        }
        
        .right-section {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-left: auto;
        }
        
        .create-btn {
            background: #00a2ff;
            color: white;
            padding: 8px 18px;
            border-radius: 6px;
            font-weight: 500;
            cursor: pointer;
        }
        
        .avatar {
            width: 36px;
            height: 36px;
            background: #00a2ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            cursor: pointer;
        }
        
        .main-container {
            display: flex;
            height: 100vh;
            padding-top: 60px;
        }
        
        .sidebar {
            width: 220px;
            background: #111;
            padding: 20px 10px;
            border-left: 1px solid #333;
            overflow-y: auto;
        }
        
        .sidebar-item {
            padding: 12px 20px;
            color: #ddd;
            cursor: pointer;
            border-radius: 6px;
            margin-bottom: 4px;
        }
        
        .sidebar-item:hover, .sidebar-item.active {
            background: #222;
            color: #00a2ff;
        }
        
        .content {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
            background: #0a0a0a;
        }
        
        .welcome {
            font-size: 28px;
            margin-bottom: 20px;
        }
        
        .section {
            margin-bottom: 40px;
        }
        
        .section-title {
            font-size: 22px;
            margin-bottom: 15px;
            color: #ddd;
        }
        
        .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 20px;
        }
        
        .game-card {
            background: #1f1f1f;
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            transition: 0.2s;
        }
        
        .game-card:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(0, 162, 255, 0.5);
        }
        
        .game-thumb {
            height: 120px;
            background: linear-gradient(45deg, #00a2ff, #ff00aa);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
        }
        
        .game-info {
            padding: 12px;
        }
        
        .game-title {
            font-size: 16px;
            margin-bottom: 4px;
        }
        
        .game-players {
            font-size: 13px;
            color: #888;
        }
        
        .modal {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.9);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2000;
        }
        
        .modal-content {
            background: #1f1f1f;
            width: 90%;
            max-width: 500px;
            border-radius: 12px;
            padding: 30px;
            text-align: center;
        }
        
        .btn {
            background: #00a2ff;
            color: white;
            border: none;
            padding: 14px 30px;
            border-radius: 8px;
            font-size: 18px;
            cursor: pointer;
            margin: 10px;
        }
        
        footer {
            text-align: center;
            padding: 15px;
            font-size: 12px;
            color: #555;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #111;
        }
    </style>
</head>
<body>
    <!-- شريط التنقل العلوي -->
    <div class="top-nav">
        <div onclick="navigate('home')" class="logo">ROBLOX</div>
        
        <div class="search-bar">
            <input type="text" id="search" placeholder="ابحث عن ألعاب أو تجارب..." onkeypress="if(event.key==='Enter') searchGames()">
        </div>
        
        <div class="nav-links">
            <a onclick="navigate('home')" class="active" id="nav-home">الرئيسية</a>
            <a onclick="navigate('discover')">اكتشف</a>
            <a onclick="navigate('market')">السوق</a>
            <a onclick="navigate('create')">أنشئ</a>
        </div>
        
        <div class="right-section">
            <div class="create-btn" onclick="showCreateModal()">+ أنشئ</div>
            <div class="avatar" onclick="showProfile()">👤</div>
        </div>
    </div>

    <div class="main-container">
        <!-- الشريط الجانبي -->
        <div class="sidebar">
            <div class="sidebar-item active" onclick="navigate('home')" id="side-home">🏠 الرئيسية</div>
            <div class="sidebar-item" onclick="navigate('discover')">🔍 اكتشف</div>
            <div class="sidebar-item" onclick="navigate('avatar')">👕 الأفاتار</div>
            <div class="sidebar-item" onclick="navigate('inventory')">🎒 المخزون</div>
            <div class="sidebar-item" onclick="navigate('friends')">👥 الأصدقاء</div>
            <div class="sidebar-item" onclick="navigate('groups')">👥 المجموعات</div>
        </div>

        <!-- المحتوى الرئيسي -->
        <div class="content" id="main-content">
            <!-- سيتم تحميل المحتوى هنا عبر JavaScript -->
            <h1 class="welcome">مرحباً بعودتك، PlayerTest123!</h1>
            
            <div class="section">
                <div class="section-title">🎮 الألعاب الموصى بها</div>
                <div class="games-grid" id="recommended-games">
                    <!-- يتم ملؤها بالجافاسكريبت -->
                </div>
            </div>
            
            <div class="section">
                <div class="section-title">🔥 الأكثر شعبية الآن</div>
                <div class="games-grid" id="popular-games">
                    <!-- يتم ملؤها بالجافاسكريبت -->
                </div>
            </div>
        </div>
    </div>

    <!-- مودال اللعب -->
    <div class="modal" id="game-modal">
        <div class="modal-content">
            <h2 id="modal-game-title">لعبة تجريبية</h2>
            <p id="modal-game-desc">هذه لعبة تجريبية مزيفة للمتعة فقط.</p>
            <button class="btn" onclick="playGame()">▶️ العب الآن</button>
            <button class="btn" style="background:#555;" onclick="closeModal()">إغلاق</button>
        </div>
    </div>

    <!-- مودال الملف الشخصي -->
    <div class="modal" id="profile-modal">
        <div class="modal-content">
            <h2>👤 PlayerTest123</h2>
            <p>Robux: <strong style="color:#ffd700">12,450</strong></p>
            <p>مستوى: 45</p>
            <button class="btn" onclick="logout()">تسجيل خروج</button>
            <button class="btn" style="background:#555;" onclick="closeModal()">إغلاق</button>
        </div>
    </div>

    <footer>
        © 2026 Roblox Corporation. هذا موقع مزيف بالكامل للتجربة الشخصية فقط.
    </footer>

    <script>
        // بيانات ألعاب وهمية
        const games = [
            {title: "Brookhaven 🏠", players: "١٢٤٬٥٦٧ يلعبون", thumb: "🏘️"},
            {title: "Adopt Me! 🐾", players: "٩٨٬٢١٣ يلعبون", thumb: "🐶"},
            {title: "Blox Fruits ⚔️", players: "١٥٧٬٨٩٠ يلعبون", thumb: "🍎"},
            {title: "Dress to Impress 👗", players: "٨٧٬٤٥٦ يلعبون", thumb: "👠"},
            {title: "Tower of Hell 🔥", players: "٦٥٬٣٢١ يلعبون", thumb: "🏗️"},
        ];

        function loadGames() {
            const rec = document.getElementById('recommended-games');
            const pop = document.getElementById('popular-games');
            
            games.forEach(game => {
                const card = `
                    <div class="game-card" onclick="openGameModal('${game.title}')">
                        <div class="game-thumb">${game.thumb}</div>
                        <div class="game-info">
                            <div class="game-title">${game.title}</div>
                            <div class="game-players">${game.players}</div>
                        </div>
                    </div>
                `;
                rec.innerHTML += card;
                pop.innerHTML += card;
            });
        }

        function openGameModal(title) {
            document.getElementById('modal-game-title').textContent = title;
            document.getElementById('game-modal').style.display = 'flex';
        }

        function closeModal() {
            document.querySelectorAll('.modal').forEach(m => m.style.display = 'none');
        }

        function playGame() {
            alert("🔄 يتم تحميل اللعبة...\n\n(موقع Roblox مزيف - اللعب غير حقيقي)");
            closeModal();
        }

        function showProfile() {
            document.getElementById('profile-modal').style.display = 'flex';
        }

        function logout() {
            alert("تم تسجيل الخروج بنجاح (تجريبي)");
            closeModal();
        }

        function showCreateModal() {
            alert("🛠️ Roblox Studio\n\n(أداة الإنشاء المزيفة - جرب إنشاء ألعابك هنا!)");
        }

        function navigate(page) {
            document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-links a').forEach(el => el.classList.remove('active'));
            
            if (page === 'home') {
                document.getElementById('main-content').innerHTML = `
                    <h1 class="welcome">مرحباً بعودتك، PlayerTest123!</h1>
                    <div class="section">
                        <div class="section-title">🎮 الألعاب الموصى بها</div>
                        <div class="games-grid" id="recommended-games"></div>
                    </div>
                    <div class="section">
                        <div class="section-title">🔥 الأكثر شعبية الآن</div>
                        <div class="games-grid" id="popular-games"></div>
                    </div>
                `;
                loadGames();
            } else if (page === 'discover') {
                document.getElementById('main-content').innerHTML = `<h1 style="color:#00a2ff">اكتشف تجارب جديدة</h1><p>هذه صفحة اكتشاف وهمية.</p>`;
            } else if (page === 'avatar') {
                document.getElementById('main-content').innerHTML = `<h1>تخصيص الأفاتار</h1><p>غير ملابسك وإكسسواراتك هنا (تجريبي).</p>`;
            }
            
            document.getElementById('side-' + page).classList.add('active');
        }

        function searchGames() {
            const term = document.getElementById('search').value;
            if (term.trim() !== '') {
                alert(`🔍 نتائج البحث عن: ${term}\n\n(نتائج وهمية)`);
            }
        }

        // تحميل الصفحة
        window.onload = () => {
            loadGames();
        };
    </script>
</body>
